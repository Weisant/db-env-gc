# LLM 服务鉴权信息
API_KEY=your_api_key_here
BASE_URL=https://your-openai-compatible-endpoint/v1

# 默认模型。
# 如果未单独指定某个阶段的模型，则会回退到 DEFAULT_MODEL。
DEFAULT_MODEL=your_default_model_here

# 可选：按阶段覆盖模型。
# 现阶段建议：
# - parser / validator 可优先用更快更便宜的模型
# - planner 用中等模型
# - generator 用效果最好的主模型
PARSER_MODEL=your_parser_model_here
PLANNER_MODEL=your_planner_model_here
GENERATOR_MODEL=your_generator_model_here
VALIDATOR_MODEL=your_validator_model_here

